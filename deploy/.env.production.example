# Zora Blog 生产环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库配置（PostgreSQL）
DATABASE_URL="postgresql://blog_prod:YOUR_DB_PASSWORD@127.0.0.1:24991/blog_prod?schema=public"

# JWT 密钥（生成一个强随机字符串）
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# API Key 盐值（用于生成管理员 API Key）
API_KEY_SALT="your-api-key-salt-random-string"

# 服务端口
PORT=3001

# Node 环境
NODE_ENV=production

# 前端 URL
SITE_URL="https://www.zorazora.cn"

# 七牛云对象存储（当前项目图片统一存放到七牛）
# 注意：bucket 必须为公开空间，否则前端直接访问图片会返回 401
QINIU_ACCESS_KEY="your-qiniu-access-key"
QINIU_SECRET_KEY="your-qiniu-secret-key"
QINIU_BUCKET="zora-markdown"
QINIU_ROOT_PREFIX="/zora_blog"
QINIU_PUBLIC_BASE_URL="https://cdn.zorazora.cn"
