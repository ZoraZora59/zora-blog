{
  "name": "zora-blog-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "lint:eslint": "eslint src/",
    "lint:all": "npm run lint && npm run lint:eslint",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "prisma:generate": "node scripts/prisma-cli.mjs generate && node scripts/sync-prisma-types.mjs",
    "prisma:migrate": "node scripts/prisma-cli.mjs migrate dev",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "npm run prisma:generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.9.8",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "prisma": "^6.16.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
